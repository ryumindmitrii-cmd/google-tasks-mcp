# Copy to your shell/session environment; do not commit real credentials or tokens.

# read_only or write
GOOGLE_TASKS_MCP_MODE=read_only

# Folder containing credentials.json and token files.
# Example:
# GOOGLE_TASKS_MCP_CONFIG_DIR=C:\Users\YourName\.egzita\google-tasks-mcp
GOOGLE_TASKS_MCP_CONFIG_DIR=

# Optional explicit token path.
# Read-only default: token.readonly.json
# Write default: token.tasks.write.json
GOOGLE_TASKS_MCP_TOKEN_FILE=

# Optional explicit OAuth Desktop client JSON path.
# Default: credentials.json inside GOOGLE_TASKS_MCP_CONFIG_DIR.
GOOGLE_TASKS_MCP_CREDENTIALS_FILE=

# Recommended for Windows/Codex stdio stability.
PYTHONUTF8=1

